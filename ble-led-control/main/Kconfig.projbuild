menu "App LED BT Controller Configuration"

    config APP_LED_BT_CONTROLLER_BT_NAME
        string "Bluetooth Device Name"
        default "ESP32_BT_LED_CTRL"
        help
            The Bluetooth device name that will be advertised by the ESP32.

    menu "LED Config"

        config APP_LED_BT_CONTROLLER_LED_PIN
            int "LED GPIO Pin Number"
            default 8
            help
                GPIO pin number connected to the LED.
                Super Mini built-in LED is usually GPIO 8.

        choice
            prompt "LED Active Level"
            default APP_LED_BT_CONTROLLER_LED_ACTIVE_LOW
            help
                Determines what voltage level turns the LED on.
                Super Mini built-in LED is active low (low = on).

            config APP_LED_BT_CONTROLLER_LED_ACTIVE_LOW
                bool "Active Low (low voltage = LED on)"

            config APP_LED_BT_CONTROLLER_LED_ACTIVE_HIGH
                bool "Active High (high voltage = LED on)"

        endchoice

        choice
            prompt "Default LED Mode"
            default APP_LED_BT_CONTROLLER_DEFAULT_MODE_BREATH
            help
                Select the initial LED effect mode after power on.

            config APP_LED_BT_CONTROLLER_DEFAULT_MODE_BREATH
                bool "Breath Mode (PWM fading)"

            config APP_LED_BT_CONTROLLER_DEFAULT_MODE_BLINK
                bool "Blink Mode (on/off toggle)"

        endchoice
        
        config APP_LED_BT_CONTROLLER_BREATH_SPEED_MS
            int "Breath Mode Step Delay (ms)"
            default 10
            range 1 50
            help
                Delay between PWM duty changes in breath mode.
                Smaller value = faster breathing.

        config APP_LED_BT_CONTROLLER_BLINK_INTERVAL_MS
            int "Blink Mode Interval (ms)"
            default 500
            range 100 2000
            help
                Time between LED state toggles in blink mode.

    endmenu

endmenu